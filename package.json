{
  "name": "goal-league-fc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "tsx server.ts",
    "test": "tsx --test tests/*.test.ts",
    "build": "tsc -b && vite build",
    "build:ssr": "tsc -b && vite build && vite build --ssr server.ts --outDir dist/server",
    "preview": "vite preview",
    "serve:ssr": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "oxlint"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-router": "^1.170.18",
    "express": "^5.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^7.0.3",
    "oxlint": "^1.71.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
